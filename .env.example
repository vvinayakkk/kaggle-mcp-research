# Kaggle Research MCP — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit your .env file. It is listed in .gitignore.

# ── Required ─────────────────────────────────────────────────────────────────

# Your Kaggle API token. Get it at:
# https://www.kaggle.com/settings -> API -> Create New Token
# Format: KGAT_ followed by a long hex string
KAGGLE_TOKEN=KGAT_your_kaggle_token_here

# Your HuggingFace API token. Get it at:
# https://huggingface.co/settings/tokens
# Recommend: "write" access for uploading datasets/models
# Format: hf_ followed by alphanumeric characters
HF_TOKEN=hf_your_huggingface_token_here

# ── Optional ─────────────────────────────────────────────────────────────────

# Override the default Kaggle API base URL (rarely needed)
# KAGGLE_API=https://www.kaggle.com/api/v1

# Override the default HuggingFace API base URL (rarely needed)
# HF_API=https://huggingface.co/api

# Log level: DEBUG | INFO | WARNING | ERROR
# LOG_LEVEL=INFO
